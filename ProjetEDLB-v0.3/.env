#type d'environnement (prod/test/dev)
APP_ENV=dev

## Variables d'environement pour la BDD

#DBEAVER user
DBEAVER_NAME=root
DBEAVER_PASSWORD=root
#Base postgres
  #utilisateur
POSTGRES_USER=root
  #nom de la DB
POSTGRES_DATABASE=edlbpostgres
  #MDP postgres
POSTGRES_PSSWRD=root
  #dossier de script de creation de bdd
POSTGRES_SCRIPTS_DIR=./data/Postgres/scripts
POSTGRES_PERSISTENCE=./data/Postgres/persistence

#Appli DBeaver : User/passwrd
DBEAVER_NAME=root
DBEAVER_PASSWRD=root
DBEAVER_PERSISTENCE=.data/cloudbeaver/persistence

#Base MongoDB
  #utilisateur mongodb
MONGODB_USER_ROOT_NAME=root
MONGODB_USER_ROOT_PASSWRD=root
  #Dossier script creation de la DB mongo
MONGODB_SCRIPTS_DIR=./data/MongoDB/scripts
  #Dossier de persistance
MONGODB_PERSISTENCE=./data/MongoDB/persistance
#Appli mongo express
MONGO_EXPRESS_USERNAME=root
MONGO_EXPRESS_PASSWRD=root
DOCKER_NUMBER=8ca

## Variables d'environement pour le back

#Variables pour la mongoDB
MONGO_DB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=edlbmongodb
MONGODB_PSSWRD=root
MONGODB_USR=root
MONGODB_AUTH=admin

JWT_KEY=0ad53e55c1d90af684615d989bf5fe3df5672a70b4041770bf964147f799494b

# Expiration du token en millisecondes
JWT_TIME=3600000

# Database config
SPRING_SOURCE=jdbc:postgresql://postgres:5432/edlbpostgres?serverTimezone=Europe/Paris
SPRING_USR=root
SPRING_PSSWRD=root
SPRING_DRIVER=org.postgresql.Driver
SPRING_PLATFORM=postgres
SPRING_DB_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=none

# Optionnel : Configure les logs de la SQL pour débogage
SPRING_SHOW_SQL=true
SPRING_FORMAT_SQL=true
SPRING_OUTPUT=always


# Configurations OAuth2 Resource Server avec JWT
OAUTH=https://idp.example.com/issuer



